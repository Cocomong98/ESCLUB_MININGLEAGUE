# Flask admin auth
ADMIN_PASSWORD=replace_with_admin_password
FLASK_SECRET_KEY=replace_with_long_random_hex

# 1 for HTTPS deployments, 0 for local HTTP only
SESSION_COOKIE_SECURE=1

# Admin session expiration policy (minutes)
ADMIN_SESSION_TTL_MINUTES=720
ADMIN_SESSION_IDLE_MINUTES=120

# Nexon Open API (do not commit real key)
NEXON_OPEN_API_KEY=replace_with_nexon_open_api_key

# Optional: private cache directory for Open API payloads
# Default (if unset): ./.private/openapi_cache
OPENAPI_CACHE_DIR=

# 1 to include raw matchId in public analysis JSON (debug only). Default OFF.
PUBLIC_ANALYSIS_INCLUDE_MATCH_ID=0

# Optional cache maintenance: 1 enables budgeted stale refresh after nightly purge.
OPENAPI_REFRESH_STALE=0
OPENAPI_REFRESH_BUDGET_PER_RUN=200

# Optional batch tuning
OPENAPI_BATCH_MAX_MATCHES=300
OPENAPI_BATCH_WINDOW_MATCHES=200
OPENAPI_BATCH_DELAY_MIN=0.8
OPENAPI_BATCH_DELAY_MAX=1.6

# Daily publish gate for dashboard/table files (KST, first run after this time)
DAILY_PUBLISH_HOUR=4
DAILY_PUBLISH_MINUTE=10

# CSP dry-run mode: 1 -> Content-Security-Policy-Report-Only
CSP_REPORT_ONLY=0
